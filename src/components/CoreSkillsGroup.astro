---
import type { Skill } from '../data/skills';

interface SubGroup {
  title: string;
  skills: Skill[];
}

interface Props {
  title: string;
  groups: SubGroup[];
}

const { title, groups } = Astro.props;
---
<div class="skill-group">
  <h6 class="skill-group-title">{title}</h6>
  <div class="core-rows">
    {groups.map(group => (
      <div class="core-row">
        <span class="core-label">{group.title}</span>
        <div class="skill-chips">
          {group.skills.map(skill => (
            <div class="skill-chip">
              <span class="skill-name">{skill.label}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .skill-group {
    margin-bottom: 36px;
  }

  .skill-group-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border-subtle);
    transition: color 0.5s ease, border-color 0.5s ease;
  }

  .core-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .core-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .core-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    min-width: 120px;
    padding-top: 7px;
    flex-shrink: 0;
    transition: color 0.5s ease;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-chip {
    background-color: var(--skill-chip-bg);
    border: 1px solid var(--skill-chip-border);
    border-radius: 6px;
    padding: 6px 12px;
    transition: border-color 0.5s ease, background-color 0.5s ease;
  }

  .skill-name {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
    transition: color 0.5s ease;
  }
</style>
