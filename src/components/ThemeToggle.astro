---
<button id="theme-toggle" class="theme-toggle" aria-label="Toggle light/dark theme">
  <i class="fa-solid fa-sun  theme-icon theme-icon--light"></i>
  <i class="fa-solid fa-moon theme-icon theme-icon--dark"></i>
</button>

<script>
  const btn = document.getElementById('theme-toggle')!;
  const html = document.documentElement;

  function updateIcon() {
    const isLight = html.classList.contains('light');
    (btn.querySelector('.theme-icon--light') as HTMLElement).style.display = isLight ? 'none' : 'inline';
    (btn.querySelector('.theme-icon--dark')  as HTMLElement).style.display = isLight ? 'inline' : 'none';
  }

  btn.addEventListener('click', () => {
    html.classList.toggle('light');
    localStorage.setItem('theme', html.classList.contains('light') ? 'light' : 'dark');
    updateIcon();
  });

  updateIcon();
</script>

<style>
  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }
  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .theme-toggle:hover i { animation: wobble 0.8s ease; }

  @media (max-width: 768px) {
    .theme-toggle { margin-left: auto; }
  }
</style>
